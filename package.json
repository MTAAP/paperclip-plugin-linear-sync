{
  "name": "@paperclipai/plugin-linear-sync",
  "version": "0.1.0",
  "description": "Linear Issue Sync plugin for Paperclip — bidirectional issue, status, and comment synchronization",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "paperclipPlugin": {
    "manifest": "./dist/manifest.js",
    "worker": "./dist/worker.js",
    "ui": "./dist/ui/"
  },
  "scripts": {
    "build": "node ./esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "dev": "node ./esbuild.config.mjs --watch",
    "clean": "rm -rf dist",
    "test": "vitest run --config ./vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "paperclip",
    "plugin",
    "connector",
    "linear"
  ],
  "author": "MTAAP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MTAAP/paperclip-plugin-linear-sync.git"
  },
  "dependencies": {
    "@paperclipai/plugin-sdk": "^1.0.0"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "esbuild": "^0.27.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rollup": "^4.38.0",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
